PORT=3001

# Banco de dados (MySQL / Aiven)
DB_HOST=seu-host.aivencloud.com
DB_USER=avnadmin
DB_PASSWORD=SUA_SENHA_AQUI
DB_NAME=todolist_rec
DB_PORT=28411

# JWT — gere um secret forte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TROQUE_POR_UM_SEGREDO_FORTE_DE_64_CHARS

# URLs (atualizar para produção)
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# E-mail (Nodemailer - Gmail)
EMAIL_USER=seu_email@gmail.com
EMAIL_PASS=sua_senha_de_app
